# ============================================================================
#  APP
# ============================================================================
APP_NAME="Interior Villa"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka
APP_URL=https://erp.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Generate APP_KEY locally with:  php artisan key:generate --show
# Paste the base64:… value into APP_KEY above.

# ============================================================================
#  DATABASE  (Coolify MySQL service)
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=interior_villa
DB_USERNAME=interior_villa
DB_PASSWORD=

# ============================================================================
#  SESSION / CACHE / QUEUE  (database-backed — no Redis needed)
# ============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
CACHE_PREFIX=
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ============================================================================
#  LOGGING
# ============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ============================================================================
#  FILESYSTEM
#  'local' reads/writes to storage/app — mounted as a Coolify persistent volume
# ============================================================================
FILESYSTEM_DISK=local

# ============================================================================
#  MAIL — for quotation emails, password resets, notifications
#  Native Resend driver (faster + better error reporting than SMTP).
#  Get an API key: https://resend.com/api-keys
# ============================================================================
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="no-reply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=

# ============================================================================
#  INTEGRATIONS
# ============================================================================
# Google Maps JavaScript API (Maps JS API + Places API enabled).
# Leave blank → maps panel shows a friendly setup notice instead of breaking.
GOOGLE_MAPS_API_KEY=

# ============================================================================
#  MISC  (rarely changed)
# ============================================================================
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12
VITE_APP_NAME="${APP_NAME}"
